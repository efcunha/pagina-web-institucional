# ============================================
# NEXT.JS / SITE CONFIGURATION
# ============================================
# Copy this file to .env.local and fill with real values
# NEVER commit .env.local to Git — it's in .gitignore for security

# Public site URL
NEXT_PUBLIC_SITE_URL=https://pagina-web-institucional.railway.app
NEXT_PUBLIC_SITE_NAME=Machado & Cunha Soft House

# ============================================
# DATABASE & BACKEND (if needed)
# ============================================
# Supabase URL (required for Contact form Edge Function)
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ============================================
# API KEYS & TOKENS (keep private!)
# ============================================
# These should NEVER be in .env.local or committed to Git
# Use Railway Secrets or environment variables instead

# Email service (if using Sendgrid, Resend, etc.)
# EMAIL_API_KEY=sk_test_1234567890
# SENDGRID_API_KEY=SG.1234567890abcdef

# Analytics
# NEXT_PUBLIC_ANALYTICS_ID=UA-1234567-89
# NEXT_PUBLIC_MIXPANEL_TOKEN=token_here

# ============================================
# FIGMA INTEGRATION (optional)
# ============================================
# Generate at https://www.figma.com/developers (Settings > Personal access tokens)
FIGMA_TOKEN=your_figma_token_here
FIGMA_FILE_KEY=your_figma_file_key_here

# ============================================
# DEVELOPMENT ONLY
# ============================================
# NODE_ENV=development
# DEBUG=nextjs:*
